APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Set true temporarily to log onboarding template field visibility (grep: OMS-HRM:template-fields)
TEMPLATE_FIELDS_DEBUG=false
# Herd: use your site URL (e.g. http://oms-hrm.test) so Vite CORS and asset URLs match.
APP_URL=http://oms-hrm.test
APP_TIMEZONE=Asia/Dubai

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=oms_hrm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Document expiry alerts (daily scheduler + queue worker; To/CC and dispatch time in Settings → Email templates)
DOCUMENT_EXPIRY_ALERT_DAYS=30
DOCUMENT_EXPIRY_ALERT_DISPATCH_AT=08:00

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Browsershot (salary declaration PDF generation on queue worker host)
# On Hostinger, enable Node.js in hPanel first. Common paths are auto-detected:
# /opt/alt/alt-nodejs20/root/usr/bin/node
# On macOS with Laravel Herd, Node is usually under:
# ~/Library/Application Support/Herd/config/nvm/versions/node/*/bin/node
# PUPPETEER_CACHE_DIR=/absolute/path/to/storage/app/puppeteer
# BROWSERSHOT_NODE_BINARY=/opt/alt/alt-nodejs20/root/usr/bin/node
# BROWSERSHOT_NPM_BINARY=/opt/alt/alt-nodejs20/root/usr/bin/npm
# BROWSERSHOT_CHROME_PATH=
